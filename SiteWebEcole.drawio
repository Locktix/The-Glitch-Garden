        <mxCell id="p6bhm-A4Cno_5fkVPJW0-25" value="Gérer mon catalogue de prestations" style="html=1;shadow=0;dashed=0;shape=mxgraph.bootstrap.rrect;rSize=5;strokeColor=none;strokeWidth=1;fillColor=#343A40;fontColor=#FFFFFF;whiteSpace=wrap;align=center;verticalAlign=middle;spacingLeft=0;fontStyle=1;fontSize=14;spacing=5;" vertex="1" parent="Hon5hjcDVI1If4CQssck-1">
