        </mxCell>
        <mxCell id="NcUNywT9UakW1Md9rzcJ-5" value="Chaque vignette est entièrement cliquable. Lorsqu’on clique dessus, la page de profil détaillée de l’artiste s’ouvre." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
