          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="5u_KgE4RDRZexbQLA-mM-1" value="Renvoie l&#39;utilisateur sur la page d&#39;accueil (programme)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
