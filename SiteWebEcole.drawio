          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="NqWRJlDDv5nCAh9NlfgH-1" value="Page de connexion, une fois cliquer, un overlay est ouvert à l&#39;artiste ou l&#39;organisteur afin de s&#39;iddentifié ou de s&#39;inscrire si l&#39;utilisateur est un artistes." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
