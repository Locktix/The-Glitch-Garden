        <mxCell id="--T3hvVJ-wkseo2-jeue-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="--T3hvVJ-wkseo2-jeue-1" target="KhnmX3Bf9Ca1SVCqI5mP-44">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="--T3hvVJ-wkseo2-jeue-1" value="Page de connexion, une fois cliquer, un overlay est ouvert à l&#39;artiste ou l&#39;organisteur afin de s&#39;iddentifié ou de s&#39;inscrire si l&#39;utilisateur est un artistes." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="890" y="110" width="150" height="170" as="geometry" />
        </mxCell>
        <mxCell id="--T3hvVJ-wkseo2-jeue-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="--T3hvVJ-wkseo2-jeue-3" target="ikLJLSdUGPxvfTNrdcM4-52">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="--T3hvVJ-wkseo2-jeue-3" value="Tableau representant la listes des artistes programmé.&lt;br&gt;Chaque case de la grille est cliquable : lorsqu’un visiteur clique sur une prestation, il est redirigé vers la page de détail correspondante, qui présente la description complète du spectacle." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="890" y="330" width="150" height="230" as="geometry" />
        </mxCell>
        <mxCell id="--T3hvVJ-wkseo2-jeue-5" value="Dans le cas où aucune prestation n’est encore programmée, la grille reste visible mais vide. Les heures et les scènes sont tout de même affichées pour conserver la structure visuelle, mais un message central informe l’utilisateur que le programme est en cours d’élaboration. Le texte peut être par exemple : “Le programme est en cours d’élaboration. Revenez bientôt !”. Une petite illustration légère, comme une horloge ou un calendrier vide, peut être ajoutée pour rendre le message plus convivial." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="760" height="140" as="geometry" />
        </mxCell>
        <mxCell id="--T3hvVJ-wkseo2-jeue-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.325;entryY=1;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="--T3hvVJ-wkseo2-jeue-5" target="ikLJLSdUGPxvfTNrdcM4-67">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
