        <mxCell id="fh1YP4tIL8WJyoJCKtYV-1" value="Chaque ligne indique le titre de la prestation, l’heure et la scène où elle se déroule. Si aucune prestation n’est encore programmée, un message s’affiche : “Vous n’avez pas encore de prestation programmée.”" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;size=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="320" width="243" height="120" as="geometry" />
        </mxCell>
